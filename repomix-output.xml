                bar.get_x() + bar.get_width() / 2,
                bar.get_height() + std + 0.3,
                f'{mean:.1f}',
                ha='center', va='bottom',
                fontsize=8, fontweight='bold',
            )

        ax.set_xticks(x)
        ax.set_xticklabels(
            [ALGO_LABELS[a] for a in algos],
            rotation=0, ha='center',
        )
