# ─────────────────────────────────────────────
# TSA Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=TSA_NEUROIPS
WANDB_ENTITY=

# Data directories (defaults to ./data if unset)
DATA_DIR=./data
LOG_DIR=./logs
CHECKPOINT_DIR=./checkpoints
RESULTS_DIR=./results

# Hardware
CUDA_VISIBLE_DEVICES=0
NUM_WORKERS=4

# WandB mode: online, offline, disabled
WANDB_MODE=offline
